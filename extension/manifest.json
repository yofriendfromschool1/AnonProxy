{
  "manifest_version": 3,
  "name": "AnonProxy Extension",
  "version": "1.0",
  "description": "Anonymous browsing extension routing through local desktop proxy.",
  "permissions": [
    "proxy",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AnonProxy",
    "default_icon": {
      "128": "icons/icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icons/icon.png"
  }
}
